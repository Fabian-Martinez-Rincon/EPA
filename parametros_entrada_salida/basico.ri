
programa EjemploBasico
areas
  ciudad: AreaC(1,1,100,100)
robots
  robot robot1
  variables
    boleana: boolean
  comenzar
    boleana := V
    Informar(boleana)
    mientras boleana
      mover
      si (PosCa = 10)
        boleana := F
  fin

variables
  R-info: robot1

comenzar
  AsignarArea(R-info, ciudad)
  Iniciar(R-info, 1, 1)
fin