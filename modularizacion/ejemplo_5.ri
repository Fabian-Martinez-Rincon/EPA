programa ejemplo_modularidad
procesos
  proceso juntar_flores
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
  fin

  proceso juntar_mover
  comenzar
    juntar_flores
    repetir 10
      mover
    derecha
  fin

  proceso cuadrado
  comenzar
    repetir 4
      juntar_mover
  fin

areas
  ciudad: AreaC(1,1,100,100)
robots
  robot robot1
  comenzar
    cuadrado
  fin

variables
  R-info:robot1
comenzar
  AsignarArea(R-info, ciudad)
  Iniciar(R-info, 1, 1)
fin